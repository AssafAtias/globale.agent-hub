# .env.host.example — environment for the CONTAINERISED server on the TLS host.
# Copy to a host-only env file (NOT committed), fill in the values, pass via
# `podman run --env-file`. Do NOT set AUTH_ENABLED=true in your LOCAL dev .env —
# localhost is plain HTTP and the Secure session cookie won't stick there.

PORT=3000
DATABASE_URL=/data/agent-hub.db

# --- Auth (Entra SSO) ---
AUTH_ENABLED=true
ENTRA_TENANT_ID=<Directory (tenant) ID from the Entra app>
ENTRA_CLIENT_ID=<Application (client) ID from the Entra app>
ENTRA_CLIENT_SECRET=<client secret value from the Entra app>
# 32 random bytes as hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<generated-32-byte-hex>
# Exact external HTTPS origin, no trailing slash. MUST equal the Entra redirect
# URI minus /auth/callback (e.g. https://agent-hub.internal).
PUBLIC_BASE_URL=https://agent-hub.internal

# --- Webhooks / integrations (set the ones you use) ---
# Real secret required in prod — the default disables signature verification.
GITLAB_WEBHOOK_SECRET=<strong-random-secret>
JIRA_WEBHOOK_SECRET=<strong-random-secret>
GITLAB_API_TOKEN=
JIRA_API_TOKEN=
JIRA_BASE_URL=https://global-e.atlassian.net
JIRA_EMAIL=
